# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
push-subscriptions.json
test-results/

# runtime data (mutated by pipeline/app, do not track)
src/data/events_latest.json
src/data/article-url-cache.json
src/data/pipeline-history.json
src/data/pipeline-stats.json
src/data/analytics.json
src/data/notification.json
src/data/dedup-log.json
src/data/*.backup-*.json
