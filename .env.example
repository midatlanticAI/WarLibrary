# Mapbox public token (create at https://account.mapbox.com/access-tokens/)
# Restrict to your domain URLs for security
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Anthropic API key for Claude AI chat (get at https://console.anthropic.com/)
# Server-side only — never prefixed with NEXT_PUBLIC_
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Admin secret for accessing admin dashboard and triggering pipeline
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
ADMIN_SECRET=your_random_secret_here

# NewsData.io API key (optional — enhances article content, free tier 200 req/day)
# Get at: https://newsdata.io/register
NEWSDATA_API_KEY=your_newsdata_key_here
