{
  "name": "War Library Admin",
  "short_name": "WL Admin",
  "description": "Admin dashboard for War Library conflict tracker.",
  "start_url": "/admin",
  "scope": "/admin",
  "display": "standalone",
  "background_color": "#0a0a0a",
